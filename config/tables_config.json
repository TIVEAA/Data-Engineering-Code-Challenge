{
    "sales": {
        "table_name": "sales",
        "format": "csv",
        "path": "data/sales_uuid.csv",
        "primary_keys": ["transaction_id"],
        "columns": {
            "transaction_id": {
                "type": "string",
                "description": "Unique identifier for the transaction"
            },
            "store_id": {
                "type": "string",
                "description": "ID of the store where the transaction occurred"   
            },
            "product_id": {
                "type": "string",
                "description": "ID of the product sold"  
            },
            "quantity": {
                "type": "integer",
                "description": "Number of units sold",
                "constraints": {
                    "min": 1
                }
            },
            "transaction_date": {
                "type": "date",
                "description": "Date of the transaction",
                "format": "YYYY-MM-DD"
            },
            "price": {
                "type": "float",
                "description": "Price per unit",
                "constraints": {
                    "min": 0.0
                }
            }
        }
    },
    "products": {
        "table_name": "products",
        "format": "csv",
        "path": "data/products_uuid.csv",
        "primary_keys": ["product_id"],
        "columns": {
            "product_id": {
                "type": "string",
                "description": "Unique identifier for the product"
            },
            "product_name": {
                "type": "string",
                "description": "Name of the product"
            },
            "category": {
                "type": "string",
                "description": "Category of the product"
            }
        }
    },
    "stores": {
        "table_name": "stores",
        "format": "csv",
        "path": "data/stores_uuid.csv",
        "primary_keys": ["store_id"],
        "columns": {
            "store_id": {
                "type": "string",
                "description": "Unique identifier for the store"  
            },
            "store_name": {
                "type": "string",
                "description": "Name of the store" 
            },
            "location": {
                "type": "string",
                "description": "Location of the store" 
            }
        }
    }
}